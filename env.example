# Template — copier ce fichier en .env (jamais commit) et remplir avec tes vraies valeurs.
# Le .env est exclu via .gitignore.

# HuggingFace — pour push les Spaces (dashboard Streamlit + API FastAPI)
# Generer un token avec scope "Write" sur https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxx

# HuggingFace username (pour creer les Spaces sous ton compte)
HF_USERNAME=ton_username_hf

# MLflow tracking (optionnel — par defaut local dans ./mlruns/)
# MLFLOW_TRACKING_URI=http://localhost:5000
